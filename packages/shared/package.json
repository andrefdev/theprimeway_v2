{
  "name": "@repo/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js",
      "default": "./src/types/index.ts"
    },
    "./validators": {
      "types": "./dist/validators/index.d.ts",
      "import": "./dist/validators/index.js",
      "default": "./src/validators/index.ts"
    },
    "./constants": {
      "types": "./dist/constants/index.d.ts",
      "import": "./dist/constants/index.js",
      "default": "./src/constants/index.ts"
    },
    "./constants/plans": {
      "types": "./dist/constants/plans.d.ts",
      "import": "./dist/constants/plans.js",
      "default": "./src/constants/plans.ts"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js",
      "default": "./src/utils/index.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "format": "biome format --write src/"
  },
  "devDependencies": {
    "@repo/config-ts": "workspace:*",
    "tsup": "^8.5.1",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "date-fns-tz": "^3.2.0",
    "zod": "^3.24.0"
  }
}
