{
  "name": "@repo/desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "dev:web+overlay": "concurrently -k -n web,overlay \"pnpm --filter @repo/web dev\" \"pnpm dev:overlay\"",
    "build": "pnpm run build:overlay && tauri build",
    "build:overlay": "vite build --config overlay/vite.config.ts",
    "dev:overlay": "vite --config overlay/vite.config.ts",
    "tauri": "tauri",
    "typecheck": "tsc --noEmit",
    "lint": "biome check overlay/src/",
    "format": "biome format --write overlay/src/",
    "clean": "rm -rf dist-overlay src-tauri/target"
  },
  "dependencies": {
    "@repo/shared": "workspace:*",
    "@repo/ui": "workspace:*",
    "@tanstack/react-query": "^5.90.0",
    "@tauri-apps/api": "^2.5.0",
    "axios": "^1.13.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "motion": "^12.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@repo/config-ts": "workspace:*",
    "@tailwindcss/vite": "^4.1.0",
    "@tauri-apps/cli": "^2.5.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "concurrently": "^9.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0",
    "vite": "^8.0.0"
  }
}
