# PostgreSQL (Docker in dev, Neon in prod)
DATABASE_URL=postgresql://theprimeway:dev123@localhost:5433/theprimeway_dev
# Optional non-pooled URL used only by `prisma migrate deploy`. Required on
# Neon (host without `-pooler`) so advisory locks survive PgBouncer recycling.
DIRECT_DATABASE_URL=

# Server
PORT=3001
NODE_ENV=development

# Auth
JWT_SECRET=your-jwt-secret-here
JWT_ACCESS_EXPIRY=7d
JWT_REFRESH_EXPIRY=30d

# Google OAuth
AUTH_GOOGLE_ID=your_google_client_id
AUTH_GOOGLE_SECRET=your_google_client_secret
# Redirect URI for Google Calendar OAuth (must match URI registered in Google Cloud Console).
# Frontend mounts <GoogleCalendarSettings/> on /settings and reads `?code=` from URL there.
GOOGLE_CALENDAR_REDIRECT_URI=https://app.theprimeway.app/settings

# Apple OAuth
AUTH_APPLE_ID=your_apple_service_id
AUTH_APPLE_SECRET=your_apple_secret

# AI provider — DeepSeek used for chat, structured outputs, background tasks
DEEPSEEK_API_KEY=your_deepseek_key

# OpenAI — used only for embeddings (text-embedding-3-small) in the brain
# concept graph pipeline. Generation stays on DeepSeek.
OPENAI_API_KEY=your_openai_key

# SMTP
SMTP_HOST=smtp.zeptomail.com
SMTP_PORT=587
SMTP_USER=emailapikey
SMTP_PASS=your_smtp_password
SMTP_FROM="ThePrimeWay <noreply@theprimeway.app>"

# Lemon Squeezy
LEMON_SQUEEZY_API_KEY=your_api_key
LEMON_SQUEEZY_STORE_ID=your_store_id
LEMON_SQUEEZY_WEBHOOK_SECRET=your_webhook_secret

# Push notifications
# Mobile (iOS + Android via Expo): EXPO_ACCESS_TOKEN is optional.
# Generate at https://expo.dev/accounts/[account]/settings/access-tokens
EXPO_ACCESS_TOKEN=

# Web (browser push via Firebase Cloud Messaging)
FIREBASE_PROJECT_ID=theprimeway-app
FIREBASE_CLIENT_EMAIL=your_service_account_email
FIREBASE_PRIVATE_KEY="your_private_key"

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_UPLOAD_PRESET=your_preset

# RapidAPI (Currency)
RAPIDAPI_KEY=your_rapidapi_key

# Sentry (https://sentry.io)
SENTRY_DSN=

# Cron + admin push API auth
# CRON_SECRET   — used as `Authorization: Bearer <secret>` by scheduled cron callers
# ADMIN_API_KEY — used as `X-API-Key: <key>` for the legacy /api/notifications/send
#                 endpoint and as an alternate auth on cron routes.
# Generate with: openssl rand -hex 32
CRON_SECRET=
ADMIN_API_KEY=
