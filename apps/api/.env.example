# PostgreSQL (Docker in dev, Neon in prod)
DATABASE_URL=postgresql://theprimeway:dev123@localhost:5433/theprimeway_dev

# Server
PORT=3001
NODE_ENV=development

# Auth
JWT_SECRET=your-jwt-secret-here
JWT_ACCESS_EXPIRY=7d
JWT_REFRESH_EXPIRY=30d

# Google OAuth
AUTH_GOOGLE_ID=your_google_client_id
AUTH_GOOGLE_SECRET=your_google_client_secret

# Apple OAuth
AUTH_APPLE_ID=your_apple_service_id
AUTH_APPLE_SECRET=your_apple_secret

# OpenAI
OPENAI_API_KEY=your_openai_key

# SMTP
SMTP_HOST=smtp.zeptomail.com
SMTP_PORT=587
SMTP_USER=emailapikey
SMTP_PASS=your_smtp_password
SMTP_FROM="ThePrimeWay <noreply@theprimeway.app>"

# Lemon Squeezy
LEMON_SQUEEZY_API_KEY=your_api_key
LEMON_SQUEEZY_STORE_ID=your_store_id
LEMON_SQUEEZY_WEBHOOK_SECRET=your_webhook_secret

# Firebase
FIREBASE_PROJECT_ID=theprimeway-app
FIREBASE_CLIENT_EMAIL=your_service_account_email
FIREBASE_PRIVATE_KEY="your_private_key"

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_UPLOAD_PRESET=your_preset

# RapidAPI (Currency)
RAPIDAPI_KEY=your_rapidapi_key

# Sentry (https://sentry.io)
SENTRY_DSN=
