datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model FinanceAccount {
  id             String    @id @default(uuid())
  userId         String?   @map("user_id")
  user           User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  type           String
  bankName       String?   @map("bank_name")
  accountNumber  String?   @map("account_number")
  currency       String?   @default("USD")
  initialBalance Decimal?  @default(0)
  currentBalance Decimal?  @default(0)
  creditLimit    Decimal?
  isActive       Boolean?  @default(true) @map("is_active")
  createdAt      DateTime? @default(now()) @map("created_at")
  updatedAt      DateTime? @default(now()) @map("updated_at")

  transactions         Transaction[] @relation("TransactionAccount")
  transferTransactions Transaction[] @relation("TransactionTransferAccount")
  savingsGoals         SavingsGoal[]
  recurringExpenses    RecurringExpense[]
  investmentHoldings   InvestmentHolding[]

  @@index([userId])
  @@map("accounts")
}

model Budget {
  id          String    @id @default(uuid())
  userId      String?   @map("user_id")
  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  periodType  String    @map("period_type")
  startDate   DateTime  @map("start_date")
  endDate     DateTime  @map("end_date")
  totalAmount Decimal   @map("total_amount")
  currency     String?   @default("USD")
  categoryType String   @default("expense") @map("category_type")
  variability  String?  @map("variability")
  isActive    Boolean?  @default(true) @map("is_active")
  isArchived  Boolean?  @default(false) @map("is_archived")
  createdAt   DateTime? @default(now()) @map("created_at")
  updatedAt   DateTime? @default(now()) @map("updated_at")

  transactions Transaction[]
  focusFinanceLinks FocusFinanceLink[]
  recurringExpenses RecurringExpense[]

  @@index([userId])
  @@map("budgets")
}

model IncomeSource {
  id                   String    @id @default(uuid())
  userId               String    @map("user_id")
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                 String
  type                 String    @default("fixed")
  category             String?
  frequency            String    @default("monthly") @map("frequency")
  baseAmount           Decimal?  @map("base_amount")
  currency             String?   @default("USD")
  probability          Decimal?  @default(1.0) @map("probability")
  estimationStrategy   String    @default("average") @map("estimation_strategy")
  historicalWindowDays Int?      @default(90) @map("historical_window_days")
  isActive             Boolean?  @default(true) @map("is_active")
  notes                String?
  createdAt            DateTime? @default(now()) @map("created_at")
  updatedAt            DateTime? @default(now()) @map("updated_at")

  transactions Transaction[]

  @@index([userId])
  @@map("income_sources")
}

model InvestmentHolding {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId       String?   @map("account_id")
  account         FinanceAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  name            String
  ticker          String?
  category        String    @default("stock") // stock | etf | mutual_fund | crypto | bond | real_estate | other
  quantity        Decimal   @default(0)
  avgCostPrice    Decimal   @default(0) @map("avg_cost_price")
  currentPrice    Decimal   @default(0) @map("current_price")
  currency        String    @default("USD")
  lastPriceUpdate DateTime? @map("last_price_update")
  notes           String?
  createdAt       DateTime? @default(now()) @map("created_at")
  updatedAt       DateTime? @default(now()) @map("updated_at")

  @@index([userId])
  @@index([accountId])
  @@map("investment_holdings")
}

model RecurringExpense {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  description String?
  type       String    @default("fixed") // fixed | variable
  category   String?   // housing, utilities, subscriptions, transport, food, health, education, entertainment, other
  frequency  String    @default("monthly") // weekly | biweekly | monthly | quarterly | yearly
  baseAmount Decimal?  @map("base_amount")
  currency   String?   @default("USD")
  dueDay     Int?      @map("due_day") // day of month (1-31)
  isAutoPay  Boolean?  @default(false) @map("is_auto_pay")
  budgetId   String?   @map("budget_id")
  accountId  String?   @map("account_id")
  isActive   Boolean?  @default(true) @map("is_active")
  notes      String?
  createdAt  DateTime? @default(now()) @map("created_at")
  updatedAt  DateTime? @default(now()) @map("updated_at")

  budget       Budget?          @relation(fields: [budgetId], references: [id], onDelete: SetNull)
  account      FinanceAccount?  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  transactions Transaction[]

  @@index([userId])
  @@index([budgetId])
  @@index([accountId])
  @@map("recurring_expenses")
}

model Debt {
  id                String    @id @default(uuid())
  userId            String    @map("user_id")
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name              String
  description       String?
  category          String?
  totalAmount       Decimal   @map("total_amount")
  paidAmount        Decimal?  @default(0) @map("paid_amount")
  currency          String?   @default("USD")
  creditor          String?
  dueDate           DateTime? @map("due_date")
  interestRate      Decimal?  @default(0) @map("interest_rate")
  isActive          Boolean?  @default(true) @map("is_active")
  paymentDay        Int?      @map("payment_day")
  installmentAmount Decimal?  @map("installment_amount")
  installmentCount  Int?      @map("installment_count")
  isRecurring       Boolean?  @default(false) @map("is_recurring")
  nextPaymentDate   DateTime? @map("next_payment_date")
  debtType          String?   @default("owed") @map("debt_type")
  createdAt         DateTime? @default(now()) @map("created_at")
  updatedAt         DateTime? @default(now()) @map("updated_at")

  transactions Transaction[]

  @@index([userId])
  @@map("debts")
}

model ExchangeRate {
  id           String    @id @default(uuid())
  fromCurrency String    @map("from_currency")
  toCurrency   String    @map("to_currency")
  rate         Decimal
  date         DateTime
  source       String    @default("api")
  createdAt    DateTime? @default(now()) @map("created_at")
  updatedAt    DateTime? @default(now()) @map("updated_at")

  @@index([fromCurrency, toCurrency, date])
  @@unique([fromCurrency, toCurrency, date])
  @@map("exchange_rates")
}

model SavingsGoal {
  id                  String    @id @default(uuid())
  userId              String?   @map("user_id")
  user                User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId           String?   @map("account_id")
  name                String
  description         String?
  targetAmount        Decimal   @map("target_amount")
  currentAmount       Decimal?  @default(0) @map("current_amount")
  currency            String?   @default("USD")
  targetDate          DateTime? @map("target_date")
  monthlyContribution Decimal?  @map("monthly_contribution")
  status              String    @default("active")
  createdAt           DateTime? @default(now()) @map("created_at")
  updatedAt           DateTime? @default(now()) @map("updated_at")

  account FinanceAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  focusFinanceLinks FocusFinanceLink[]

  @@index([userId])
  @@map("savings_goals")
}

model ImportBatch {
  id                String    @id @default(uuid())
  userId            String    @map("user_id")
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  batchName         String    @map("batch_name")
  totalTransactions Int       @default(0) @map("total_transactions")
  importedAt        DateTime? @default(now()) @map("imported_at")
  status            String    @default("pending_review")
  createdAt         DateTime? @default(now()) @map("created_at")
  updatedAt         DateTime? @default(now()) @map("updated_at")

  transactions Transaction[]

  @@index([userId])
  @@map("import_batches")
}

model UserCurrencySettings {
  id                  String    @id @default(uuid())
  userId              String    @map("user_id")
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  baseCurrency        String    @default("USD") @map("base_currency")
  preferredCurrencies Json      @map("preferred_currencies")
  createdAt           DateTime? @default(now()) @map("created_at")
  updatedAt           DateTime? @default(now()) @map("updated_at")

  @@unique([userId])
  @@map("user_currency_settings")
}

model Transaction {
  id                 String    @id @default(uuid())
  userId             String    @map("user_id")
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId          String    @map("account_id")
  budgetId           String?   @map("budget_id")
  debtId             String?   @map("debt_id")
  incomeSourceId     String?   @map("income_source_id")
  recurringExpenseId String?   @map("recurring_expense_id")
  type               String
  amount             Decimal
  description        String
  notes              String?
  date               DateTime
  isRecurring        Boolean?  @default(false) @map("is_recurring")
  recurringPattern   String?   @map("recurring_pattern")
  transferAccountId  String?   @map("transfer_account_id")
  tags               Json
  receiptUrl         String?   @map("receipt_url")
  status             String    @default("pending")
  reviewedAt         DateTime? @map("reviewed_at")
  reviewedBy         String?   @map("reviewed_by")
  exclusionReason    String?   @map("exclusion_reason")
  sourceType         String    @default("manual") @map("source_type")
  importBatchId      String?   @map("import_batch_id")
  createdAt          DateTime? @default(now()) @map("created_at")
  updatedAt          DateTime? @default(now()) @map("updated_at")
  exchangeRate       Decimal?  @default(1.0) @map("exchange_rate")
  currency           String?   @default("USD")
  baseCurrencyAmount Decimal?  @map("base_currency_amount")
  exchangeRateDate   DateTime? @map("exchange_rate_date")
  isManualRate       Boolean?  @default(false) @map("is_manual_rate")

  account         FinanceAccount  @relation("TransactionAccount", fields: [accountId], references: [id], onDelete: Cascade)
  budget          Budget?         @relation(fields: [budgetId], references: [id], onDelete: SetNull)
  debt            Debt?           @relation(fields: [debtId], references: [id], onDelete: SetNull)
  incomeSource    IncomeSource?    @relation(fields: [incomeSourceId], references: [id], onDelete: SetNull)
  recurringExpense RecurringExpense? @relation(fields: [recurringExpenseId], references: [id], onDelete: SetNull)
  transferAccount FinanceAccount? @relation("TransactionTransferAccount", fields: [transferAccountId], references: [id], onDelete: SetNull)
  importBatch     ImportBatch?    @relation(fields: [importBatchId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, status])
  @@index([userId, type])
  @@index([userId, date])
  @@index([userId, status, date])
  @@index([accountId])
  @@index([budgetId])
  @@index([debtId])
  @@index([incomeSourceId])
  @@index([recurringExpenseId])
  @@index([importBatchId])
  @@index([date])
  @@map("transactions")
}

model SubscriptionPlan {
  id                       String    @id @default(uuid())
  name                     String
  displayName              String    @map("display_name")
  description              String?
  price                    Decimal
  currency                 String    @default("USD")
  billingInterval          String    @default("monthly") @map("billing_interval")
  lemonSqueezyProductId    String?   @map("lemon_squeezy_product_id")
  lemonSqueezyVariantId    String?   @unique @map("lemon_squeezy_variant_id")
  trialPeriodDays          Int?      @default(14) @map("trial_period_days")
  maxHabits                Int?      @default(5) @map("max_habits")
  maxGoals                 Int?      @default(3) @map("max_goals")
  maxNotes                 Int?      @default(50) @map("max_notes")
  maxTasks                 Int?      @default(20) @map("max_tasks")
  maxPomodoroSessionsDaily Int?      @default(10) @map("max_pomodoro_sessions_daily")
  hasAiAssistant           Boolean?  @default(false) @map("has_ai_assistant")
  hasReadingModule         Boolean?  @default(false) @map("has_reading_module")
  hasFinancesModule        Boolean?  @default(false) @map("has_finances_module")
  hasNotesModule           Boolean?  @default(false) @map("has_notes_module")
  hasAdvancedAnalytics     Boolean?  @default(false) @map("has_advanced_analytics")
  hasCustomThemeCreation   Boolean?  @default(false) @map("has_custom_theme_creation")
  hasExportData            Boolean?  @default(false) @map("has_export_data")
  hasPrioritySupport       Boolean?  @default(false) @map("has_priority_support")
  isActive                 Boolean?  @default(true) @map("is_active")
  sortOrder                Int?      @default(0) @map("sort_order")
  createdAt                DateTime? @default(now()) @map("created_at")
  updatedAt                DateTime? @default(now()) @map("updated_at")

  subscriptions UserSubscription[]

  @@map("subscription_plans")
}

model Habit {
  id              String    @id @default(uuid())
  userId          String?   @map("user_id")
  user            User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  category        String?
  color           String?   @default("#3B82F6")
  targetFrequency Int?      @default(1) @map("target_frequency")
  frequencyType   String?   @map("frequency_type")
  weekDays        Json?     @map("week_days")
  isActive        Boolean?  @default(true) @map("is_active")
  goalId          String?   @map("goal_id")
  createdAt       DateTime? @default(now()) @map("created_at")
  updatedAt       DateTime? @default(now()) @map("updated_at")

  logs HabitLog[]
  focusHabitLinks FocusHabitLink[]

  @@index([userId])
  @@index([userId, isActive])
  @@index([goalId])
  @@map("habits")
}

model HabitLog {
  id             String    @id @default(uuid())
  habitId        String?   @map("habit_id")
  userId         String?   @map("user_id")
  user           User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date           DateTime
  completedCount Int?      @default(0) @map("completed_count")
  notes          String?
  createdAt      DateTime? @default(now()) @map("created_at")
  updatedAt      DateTime? @default(now()) @map("updated_at")

  habit Habit? @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@index([userId])
  @@map("habit_logs")
}

model LemonSqueezyWebhook {
  id             String    @id @default(uuid())
  eventName      String    @map("event_name")
  lemonSqueezyId String?   @map("lemon_squeezy_id")
  userId         String?   @map("user_id")
  user           User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionId String?   @map("subscription_id")
  webhookData    Json      @map("webhook_data")
  processed      Boolean?  @default(false)
  errorMessage   String?   @map("error_message")
  createdAt      DateTime? @default(now()) @map("created_at")

  subscription UserSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("lemon_squeezy_webhooks")
}

model NoteCategory {
  id        String    @id @default(uuid())
  userId    String?   @map("user_id")
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  color     String?   @default("#6B7280")
  icon      String?
  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime? @default(now()) @map("updated_at")

  notes Note[]

  @@index([userId])
  @@map("note_categories")
}

model Note {
  id         String    @id @default(uuid())
  userId     String?   @map("user_id")
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String?   @map("category_id")
  title      String
  content    String?
  tags       Json
  isPinned   Boolean?  @default(false) @map("is_pinned")
  isArchived Boolean?  @default(false) @map("is_archived")
  deletedAt  DateTime? @map("deleted_at")
  createdAt  DateTime? @default(now()) @map("created_at")
  updatedAt  DateTime? @default(now()) @map("updated_at")

  category NoteCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([categoryId])
  @@index([userId, deletedAt])
  @@map("notes")
}

model PomodoroDailyStat {
  id             String    @id @default(uuid())
  userId         String?   @map("user_id")
  user           User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date           DateTime
  focusSessions  Int?      @default(0) @map("focus_sessions")
  shortBreaks    Int?      @default(0) @map("short_breaks")
  longBreaks     Int?      @default(0) @map("long_breaks")
  totalFocusTime Int?      @default(0) @map("total_focus_time")
  totalBreakTime Int?      @default(0) @map("total_break_time")
  createdAt      DateTime? @default(now()) @map("created_at")
  updatedAt      DateTime? @default(now()) @map("updated_at")

  @@unique([userId, date])
  @@index([userId])
  @@map("pomodoro_daily_stats")
}

model PomodoroSession {
  id              String    @id @default(uuid())
  userId          String?   @map("user_id")
  user            User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId          String?   @map("task_id")
  sessionType     String    @default("focus") @map("session_type")
  plannedDuration Int       @map("planned_duration")
  actualDuration  Int?      @map("actual_duration")
  startedAt       DateTime  @map("started_at")
  completedAt     DateTime? @map("completed_at")
  isCompleted     Boolean?  @default(false) @map("is_completed")
  notes           String?
  createdAt       DateTime? @default(now()) @map("created_at")

  task Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([taskId])
  @@map("pomodoro_sessions")
}

model Task {
  id          String    @id @default(uuid())
  userId      String?   @map("user_id")
  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weeklyGoalId String?   @map("weekly_goal_id")
  title       String
  description String?
  status      String    @default("open")  // open | completed
  priority    String    @default("medium")
  dueDate     DateTime? @map("due_date")
  completedAt DateTime? @map("completed_at")
  tags        Json
  estimatedDurationMinutes Int?      @map("estimated_duration_minutes")
  actualDurationMinutes    Int?      @default(0) @map("actual_duration_minutes")
  actualDurationSeconds    Int?      @default(0) @map("actual_duration_seconds")
  scheduledDate            DateTime? @map("scheduled_date")      // YYYY-MM-DD intent (stored as datetime)
  scheduledStart           DateTime? @map("scheduled_start")     // Full datetime for calendar
  scheduledEnd             DateTime? @map("scheduled_end")       // Full datetime for calendar
  actualStart              DateTime? @map("actual_start")        // When task actually started
  actualEnd                DateTime? @map("actual_end")          // When task actually ended
  isAllDay                 Boolean?  @default(false) @map("is_all_day")
  source                   String?   @default("manual")          // manual|autoschedule|dragged|recovered
  backlogState             String?   @default("none") @map("backlog_state")
  archivedAt               DateTime? @map("archived_at")         // When task was archived
  orderInDay               Int?      @map("order_in_day")        // Sort order within day
  lockedTime               Boolean?  @default(false) @map("locked_time")  // User pinned time slot
  syncToCalendar           Boolean?  @default(false) @map("sync_to_calendar") // Sync task to Google Calendar
  lastReminderSentAt       DateTime? @map("last_reminder_sent_at")         // Prevent duplicate reminders
  aiTimebox                Int?      @map("ai_timebox")                    // AI-suggested timebox in minutes
  aiInsightJson            Json?     @map("ai_insight_json")               // AI-generated insights for task
  isRecurring              Boolean   @default(false) @map("is_recurring")
  recurrenceRule           String?   @map("recurrence_rule")               // "daily", "weekly", "monthly", "weekdays", "custom:MO,WE,FR"
  recurringParentId        String?   @map("recurring_parent_id")           // If this task is an instance generated from a recurring parent
  recurrenceEndDate        DateTime? @map("recurrence_end_date")
  createdAt   DateTime? @default(now()) @map("created_at")
  updatedAt   DateTime? @default(now()) @map("updated_at")

  sessions PomodoroSession[]
  focusTaskLinks FocusTaskLink[]
  calendarBindings TaskCalendarBinding[]
  weeklyGoal WeeklyGoal? @relation(fields: [weeklyGoalId], references: [id], onDelete: SetNull)
  recurringParent    Task?     @relation("RecurringInstances", fields: [recurringParentId], references: [id], onDelete: SetNull)
  recurringInstances Task[]    @relation("RecurringInstances")

  @@index([userId])
  @@index([userId, status])
  @@index([userId, scheduledDate])
  @@index([weeklyGoalId])
  @@index([recurringParentId])
  @@map("tasks")
}


model HealthMetric {
  id           String    @id @default(uuid())
  userId       String?   @map("user_id")
  user         User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         String
  unit         String?
  numericValue Decimal?  @map("numeric_value")
  stringValue  String?   @map("string_value")
  date         DateTime
  notes        String?
  metadata     Json?
  createdAt    DateTime? @default(now()) @map("created_at")
  updatedAt    DateTime? @default(now()) @map("updated_at")

  @@index([userId, type, date])
  @@map("health_metrics")
}

model UserProfile {
  id                          String    @id @default(uuid())
  userId                      String?   @map("user_id")
  user                        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName                   String?   @map("first_name")
  lastName                    String?   @map("last_name")
  displayName                 String?   @map("display_name")
  profilePicture      String?   @map("profile_picture")
  bio                 String?
  primaryGoal         String?   @map("primary_goal")
  lastProfileUpdate   DateTime? @default(now()) @map("last_profile_update")
  createdAt                   DateTime? @default(now()) @map("created_at")
  updatedAt                   DateTime? @default(now()) @map("updated_at")

  @@unique([userId])
  @@map("user_profiles")
}

model UserSettings {
  id        String    @id @default(uuid())
  userId    String?   @map("user_id")
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  locale    String    @default("en")
  theme     String    @default("dark")
  timezone  String    @default("UTC")
  aiDataSharing Boolean   @default(true) @map("ai_data_sharing")
  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime? @default(now()) @map("updated_at")

  @@unique([userId])
  @@map("user_settings")
}

model UserSubscription {
  id                         String    @id @default(uuid())
  userId                     String?   @map("user_id")
  user                       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId                     String?   @map("plan_id")
  lemonSqueezySubscriptionId String?   @map("lemon_squeezy_subscription_id")
  lemonSqueezyOrderId        String?   @map("lemon_squeezy_order_id")
  lemonSqueezyCustomerId     String?   @map("lemon_squeezy_customer_id")
  updatePaymentMethodUrl     String?   @map("update_payment_method_url")
  status                     String?   @default("pending")
  currency                   String?   @default("USD")
  amount                     Decimal
  billingInterval            String    @map("billing_interval")
  trialStartsAt              DateTime? @map("trial_starts_at")
  trialEndsAt                DateTime? @map("trial_ends_at")
  startsAt                   DateTime  @map("starts_at")
  endsAt                     DateTime? @map("ends_at")
  cancelledAt                DateTime? @map("cancelled_at")
  nextBillingDate            DateTime? @map("next_billing_date")
  metadata                   Json?     @map("metadata")
  createdAt                  DateTime? @default(now()) @map("created_at")
  updatedAt                  DateTime? @default(now()) @map("updated_at")

  plan     SubscriptionPlan?     @relation(fields: [planId], references: [id], onDelete: SetNull)
  webhooks LemonSqueezyWebhook[]

  @@unique([lemonSqueezySubscriptionId])
  @@index([userId])
