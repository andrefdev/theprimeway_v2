// ============================================================
// VISION-TO-EXECUTION OS (Phase 1 — additive)
// Companion to legacy goal/habit models; data migration in scripts/migrations/v2/
// ============================================================

// ----- Vision (singleton per user) -----
model Vision {
  id                 String    @id @default(uuid())
  userId             String    @unique @map("user_id")
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  statement          String // "By 2036 I am..."
  coreValues         String[]  @map("core_values") // 3-5 values
  identityStatements String[]  @map("identity_statements") // future-self statements
  lastReviewedAt     DateTime? @map("last_reviewed_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@map("visions")
}

// ----- Goal (unified 3Y/1Y/Q/W) -----
enum GoalHorizon {
  THREE_YEAR
  ONE_YEAR
  QUARTER
  WEEK
}

enum GoalStatus {
  ACTIVE
  ACHIEVED
  RETIRED
}

model Goal {
  id                 String      @id @default(uuid())
  userId             String      @map("user_id")
  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  horizon            GoalHorizon
  parentGoalId       String?     @map("parent_goal_id")
  parentGoal         Goal?       @relation("GoalHierarchy", fields: [parentGoalId], references: [id], onDelete: SetNull)
  childGoals         Goal[]      @relation("GoalHierarchy")
  channelId          String?     @map("channel_id")
  channel            Channel?    @relation(fields: [channelId], references: [id], onDelete: SetNull)
  title              String
  description        String?
  targetMetric       String?     @map("target_metric")
  objectives         Json?
  status             GoalStatus  @default(ACTIVE)
  startsOn           DateTime?   @map("starts_on") @db.Date
  endsOn             DateTime?   @map("ends_on") @db.Date
  periodKey          String?     @map("period_key") // "2026-Q2" | "2026-W17"
  visionContribution Float       @default(0) @map("vision_contribution") // 0..1
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  taskLinks   TaskGoal[]
  reflections ReflectionEntry[]

  @@index([userId, horizon])
  @@index([userId, status])
  @@index([periodKey])
  @@index([parentGoalId])
  @@map("goals")
}

// ----- Task <-> Goal M2M -----
model TaskGoal {
  taskId    String   @map("task_id")
  goalId    String   @map("goal_id")
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  goal      Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@id([taskId, goalId])
  @@index([goalId])
  @@map("task_goals")
}

// ----- Context & Channel -----
model Context {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  color      String   @default("#3B82F6")
  isPersonal Boolean  @default(false) @map("is_personal")
  position   Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  channels Channel[]

  @@index([userId])
  @@map("contexts")
}

model Channel {
  id                   String   @id @default(uuid())
  userId               String   @map("user_id")
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contextId            String   @map("context_id")
  context              Context  @relation(fields: [contextId], references: [id], onDelete: Cascade)
  name                 String // "#deepwork", "#client-x"
  color                String   @default("#3B82F6")
  isDefault            Boolean  @default(false) @map("is_default")
  isEnabled            Boolean  @default(true) @map("is_enabled")
  importFromCalendarId String?  @map("import_from_calendar_id")
  timeboxToCalendarId  String?  @map("timebox_to_calendar_id")
  slackChannelId       String?  @map("slack_channel_id")
  asanaProjectId       String?  @map("asana_project_id")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  tasks                 Task[]
  goals                 Goal[]
  workingHoursOverrides WorkingHours[]

  @@index([userId])
  @@index([contextId])
  @@map("channels")
}

// ----- Subtask -----
model Subtask {
  id                 String   @id @default(uuid())
  taskId             String   @map("task_id")
  task               Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  title              String
  isCompleted        Boolean  @default(false) @map("is_completed")
  plannedTimeMinutes Int?     @map("planned_time_minutes")
  actualTimeMinutes  Int      @default(0) @map("actual_time_minutes")
  position           Float    @default(0)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([taskId])
  @@map("subtasks")
}

// ----- WorkingSession (the "when") -----
enum SessionKind {
  WORK
  POMODORO
  BREAK
  HABIT_LOG
}

enum CreationSource {
  USER
  AUTO_SCHEDULE
  AUTO_RESCHEDULE
  SPLIT
  IMPORT
}

model WorkingSession {
  id                 String         @id @default(uuid())
  userId             String         @map("user_id")
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId             String?        @map("task_id")
  task               Task?          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  kind               SessionKind    @default(WORK)
  start              DateTime
  end                DateTime
  externalCalendarId String?        @map("external_calendar_id")
  externalEventId    String?        @map("external_event_id")
  createdBy          CreationSource @default(USER) @map("created_by")
  completed          Boolean        @default(false)
  notes              String?
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  @@index([userId, start])
  @@index([taskId])
  @@map("working_sessions")
}

// ----- WorkingHours -----
model WorkingHours {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channelId String?  @map("channel_id")
  channel   Channel? @relation(fields: [channelId], references: [id], onDelete: Cascade)
  dayOfWeek Int      @map("day_of_week") // 0=Sunday .. 6=Saturday
  startTime String   @map("start_time") // "09:00"
  endTime   String   @map("end_time") // "17:00"
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([channelId])
  @@map("working_hours")
}

// ----- RecurringSeries -----
enum RecurrencePattern {
  DAILY
  WEEKDAYS
  WEEKLY
  MONTHLY
}

model RecurringSeries {
  id               String            @id @default(uuid())
  userId           String            @map("user_id")
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateTaskJson Json              @map("template_task_json")
  pattern          RecurrencePattern
  daysOfWeek       Int[]             @map("days_of_week")
  atRoughlyTime    String?           @map("at_roughly_time") // "09:00"
  startDate        DateTime          @map("start_date")
  endDate          DateTime?         @map("end_date")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  tasks Task[]

  @@index([userId])
  @@map("recurring_series")
}

// ----- CalendarEvent (cache from external provider) -----
model CalendarEvent {
  id         String   @id @default(uuid())
  calendarId String   @map("calendar_id")
  calendar   Calendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  externalId String   @map("external_id")
  title      String
  start      DateTime
  end        DateTime
  isBusy     Boolean  @default(true) @map("is_busy")
  isDeclined Boolean  @default(false) @map("is_declined")
  isAllDay   Boolean  @default(false) @map("is_all_day")
  syncedAt   DateTime @default(now()) @map("synced_at")

  @@unique([calendarId, externalId])
  @@index([calendarId, start])
  @@map("calendar_events")
}

// ----- Rituals -----
enum RitualKind {
  DAILY_PLAN
  DAILY_SHUTDOWN
  WEEKLY_PLAN
  WEEKLY_REVIEW
  QUARTERLY_REVIEW
  ANNUAL_REVIEW
  CUSTOM
}

enum RitualCadence {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  ANNUALLY
  ON_DEMAND
}

enum RitualStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

model Ritual {
  id            String        @id @default(uuid())
  userId        String?       @map("user_id") // null = system template
  user          User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind          RitualKind
  name          String
  cadence       RitualCadence
  scheduledTime String?       @map("scheduled_time") // "08:00" or cron-like
  steps         Json // [{type:"PROMPT", key, text}, ...]
  isEnabled     Boolean       @default(true) @map("is_enabled")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  instances RitualInstance[]

  @@index([userId, kind])
  @@map("rituals")
}

model RitualInstance {
  id           String       @id @default(uuid())
  ritualId     String       @map("ritual_id")
  ritual       Ritual       @relation(fields: [ritualId], references: [id], onDelete: Cascade)
  userId       String       @map("user_id")
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduledFor DateTime     @map("scheduled_for")
  startedAt    DateTime?    @map("started_at")
  completedAt  DateTime?    @map("completed_at")
  status       RitualStatus @default(PENDING)
  snapshot     Json? // captured state at completion
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  reflections ReflectionEntry[]

  @@index([userId, scheduledFor])
  @@index([ritualId])
  @@map("ritual_instances")
}

model ReflectionEntry {
  id               String         @id @default(uuid())
  ritualInstanceId String         @map("ritual_instance_id")
  ritualInstance   RitualInstance @relation(fields: [ritualInstanceId], references: [id], onDelete: Cascade)
  promptKey        String         @map("prompt_key")
  body             String
  attachedGoalId   String?        @map("attached_goal_id")
  attachedGoal     Goal?          @relation(fields: [attachedGoalId], references: [id], onDelete: SetNull)
  createdAt        DateTime       @default(now()) @map("created_at")

  @@index([ritualInstanceId])
  @@map("reflection_entries")
}

// ----- Command (granular undo) -----
enum CommandSource {
  USER_ACTION
  AUTO_RESCHEDULER
  ROLLOVER_JOB
  SYNC_JOB
}

model Command {
  id              String        @id @default(uuid())
  userId          String        @map("user_id")
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            String // "AUTO_RESCHEDULE" | "MOVE_SESSION" | ...
  payload         Json // { changes: [{entity, id, before, after}, ...] }
  isUndone        Boolean       @default(false) @map("is_undone")
  triggeredBy     CommandSource @map("triggered_by")
  parentCommandId String?       @map("parent_command_id")
  parent          Command?      @relation("CommandChildren", fields: [parentCommandId], references: [id], onDelete: SetNull)
  children        Command[]     @relation("CommandChildren")
  createdAt       DateTime      @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@map("commands")
}

// ----- TimerEvent (for late-timer detector + audit) -----
enum TimerEventType {
  START
  PAUSE
  RESUME
  STOP
  COMPLETE
}

model TimerEvent {
  id        String         @id @default(uuid())
  taskId    String         @map("task_id")
  task      Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  type      TimerEventType
  timestamp DateTime       @default(now())
  metadata  Json? // { previousSessionStart, movedTo, ... }

  @@index([taskId, timestamp])
  @@map("timer_events")
}

// ----- Task additive enum -----
enum TaskKind {
  TASK
  HABIT
}
