  sourceId   String?  @map("source_id") // ID of the task/habit/session that generated XP
  amount     Int
  metadata   Json?    // e.g. { priority: "high", taskTitle: "..." }
  earnedAt   DateTime @default(now()) @map("earned_at")
  earnedDate String   @map("earned_date") // YYYY-MM-DD in user's timezone for daily aggregation

  @@index([userId])
  @@index([userId, earnedDate])
  @@index([userId, source])
  @@map("xp_events")
}

model DailyXpSnapshot {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date       String   // YYYY-MM-DD
  totalXp    Int      @default(0) @map("total_xp")
  goalMet    Boolean  @default(false) @map("goal_met")
  taskXp     Int      @default(0) @map("task_xp")
  habitXp    Int      @default(0) @map("habit_xp")
  pomodoroXp Int      @default(0) @map("pomodoro_xp")
  bonusXp    Int      @default(0) @map("bonus_xp")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([userId, date])
  @@index([userId])
  @@map("daily_xp_snapshots")
}

model Achievement {
  id        String @id @default(uuid())
  key       String @unique // "first_task", "streak_7", "rank_s", etc.
  category  String // tasks | habits | streaks | pomodoro | milestones | ranks
  titleEn   String @map("title_en")
  titleEs   String @map("title_es")
  descEn    String @map("desc_en")
  descEs    String @map("desc_es")
  iconName  String @map("icon_name") // lucide icon name
  xpReward  Int    @default(0) @map("xp_reward")
  condition Json   // { type: "streak_days", value: 7 } or { type: "total_xp", value: 1000 }
  rarity    String @default("common") // common | rare | epic | legendary
  sortOrder Int    @default(0) @map("sort_order")

  userAchievements UserAchievement[]
  userProgress     UserAchievementProgress[]

  @@map("achievements")
}

model UserAchievement {
  id            String      @id @default(uuid())
  userId        String      @map("user_id")
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String      @map("achievement_id")
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  unlockedAt    DateTime    @default(now()) @map("unlocked_at")

  @@unique([userId, achievementId])
  @@index([userId])
  @@map("user_achievements")
}

model UserAchievementProgress {
  id            String      @id @default(uuid())
  userId        String      @map("user_id")
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String      @map("achievement_id")
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  value         Int         @default(0)
  target        Int         @default(0)
  met           Boolean     @default(false)
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@unique([userId, achievementId])
  @@index([userId])
  @@map("user_achievement_progress")
}

model DailyChallenge {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date         String   // YYYY-MM-DD
  type         String   // complete_tasks | pomodoro_sessions | habit_streak | earn_xp
  titleEn      String   @map("title_en")
  titleEs      String   @map("title_es")
  descEn       String   @map("desc_en")
  descEs       String   @map("desc_es")
  xpReward     Int      @map("xp_reward")
  targetValue  Int      @map("target_value")
  currentValue Int      @default(0) @map("current_value")
  isCompleted  Boolean  @default(false) @map("is_completed")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([userId, date, type])
  @@index([userId, date])
  @@map("daily_challenges")
}
