// ============================================================
// VISION-TO-EXECUTION OS (Phase 1 — additive)
// Companion to legacy goal/habit models; data migration in scripts/migrations/v2/
// ============================================================

// ----- Vision (singleton per user) -----
model Vision {
  id                 String    @id @default(uuid())
  userId             String    @unique @map("user_id")
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  statement          String // "By 2036 I am..."
  coreValues         String[]  @map("core_values") // 3-5 values
  identityStatements String[]  @map("identity_statements") // future-self statements
  lastReviewedAt     DateTime? @map("last_reviewed_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@map("visions")
}

// ----- Goal (unified 3Y/1Y/Q/W) -----
enum GoalHorizon {
  THREE_YEAR
  ONE_YEAR
  QUARTER
  WEEK
}

enum GoalStatus {
  ACTIVE
  ACHIEVED
  RETIRED
}

model Goal {
  id                 String      @id @default(uuid())
  userId             String      @map("user_id")
  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  horizon            GoalHorizon
  parentGoalId       String?     @map("parent_goal_id")
  parentGoal         Goal?       @relation("GoalHierarchy", fields: [parentGoalId], references: [id], onDelete: SetNull)
  childGoals         Goal[]      @relation("GoalHierarchy")
  channelId          String?     @map("channel_id")
  channel            Channel?    @relation(fields: [channelId], references: [id], onDelete: SetNull)
  title              String
  description        String?
  targetMetric       String?     @map("target_metric")
  objectives         Json?
  status             GoalStatus  @default(ACTIVE)
  startsOn           DateTime?   @map("starts_on") @db.Date
  endsOn             DateTime?   @map("ends_on") @db.Date
  periodKey          String?     @map("period_key") // "2026-Q2" | "2026-W17"
  visionContribution Float       @default(0) @map("vision_contribution") // 0..1
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  taskLinks   TaskGoal[]
  reflections ReflectionEntry[]

  @@index([userId, horizon])
  @@index([userId, status])
  @@index([periodKey])
  @@index([parentGoalId])
  @@map("goals")
}

// ----- Task <-> Goal M2M -----
model TaskGoal {
  taskId    String   @map("task_id")
  goalId    String   @map("goal_id")
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  goal      Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@id([taskId, goalId])
  @@index([goalId])
  @@map("task_goals")
}

// ----- Context & Channel -----
model Context {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  color      String   @default("#3B82F6")
  isPersonal Boolean  @default(false) @map("is_personal")
  position   Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  channels Channel[]

  @@index([userId])
  @@map("contexts")
}

model Channel {
  id                   String   @id @default(uuid())
  userId               String   @map("user_id")
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contextId            String   @map("context_id")
  context              Context  @relation(fields: [contextId], references: [id], onDelete: Cascade)
  name                 String // "#deepwork", "#client-x"
  color                String   @default("#3B82F6")
  isDefault            Boolean  @default(false) @map("is_default")
  isEnabled            Boolean  @default(true) @map("is_enabled")
  importFromCalendarId String?  @map("import_from_calendar_id")
  timeboxToCalendarId  String?  @map("timebox_to_calendar_id")
  slackChannelId       String?  @map("slack_channel_id")
  asanaProjectId       String?  @map("asana_project_id")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  tasks                 Task[]
  goals                 Goal[]
  workingHoursOverrides WorkingHours[]

  @@index([userId])
  @@index([contextId])
  @@map("channels")
}

// ----- Subtask -----
model Subtask {
  id                 String   @id @default(uuid())
  taskId             String   @map("task_id")
  task               Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  title              String
  isCompleted        Boolean  @default(false) @map("is_completed")
  plannedTimeMinutes Int?     @map("planned_time_minutes")
  actualTimeMinutes  Int      @default(0) @map("actual_time_minutes")
  position           Float    @default(0)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([taskId])
  @@map("subtasks")
}

// ----- WorkingSession (the "when") -----
enum SessionKind {
  WORK
  POMODORO
  BREAK
  HABIT_LOG
}

enum CreationSource {
  USER
  AUTO_SCHEDULE
  AUTO_RESCHEDULE
  SPLIT
  IMPORT
}

model WorkingSession {
  id                 String         @id @default(uuid())
  userId             String         @map("user_id")
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId             String?        @map("task_id")
  task               Task?          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  kind               SessionKind    @default(WORK)
  start              DateTime
  end                DateTime
  externalCalendarId String?        @map("external_calendar_id")
  externalEventId    String?        @map("external_event_id")
  createdBy          CreationSource @default(USER) @map("created_by")
  completed          Boolean        @default(false)
  notes              String?
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  @@index([userId, start])
  @@index([taskId])
  @@map("working_sessions")
}

// ----- WorkingHours -----
model WorkingHours {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channelId String?  @map("channel_id")
  channel   Channel? @relation(fields: [channelId], references: [id], onDelete: Cascade)
  dayOfWeek Int      @map("day_of_week") // 0=Sunday .. 6=Saturday in user's local tz
  // Local-clock "HH:mm" interpreted in UserSettings.timezone. Never store device-local times.
  startTime String   @map("start_time") // "09:00"
  endTime   String   @map("end_time") // "17:00"
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([channelId])
  @@map("working_hours")
}

// Per-day override of working hours (Sunsama-style draggable day bars).
// When present, takes precedence over WorkingHours for that user+date.
model WorkingHoursOverride {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String // YYYY-MM-DD in user's tz
  startTime String   @map("start_time") // "HH:mm"
  endTime   String   @map("end_time") // "HH:mm"
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, date])
  @@index([userId])
  @@map("working_hours_overrides")
}

// ----- RecurringSeries -----
enum RecurrencePattern {
  DAILY
  WEEKDAYS
  WEEKLY
  MONTHLY
}

model RecurringSeries {
  id               String            @id @default(uuid())
  userId           String            @map("user_id")
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateTaskJson Json              @map("template_task_json")
  pattern          RecurrencePattern
  daysOfWeek       Int[]             @map("days_of_week")
  atRoughlyTime    String?           @map("at_roughly_time") // "09:00"
  startDate        DateTime          @map("start_date")
  endDate          DateTime?         @map("end_date")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  tasks Task[]

  @@index([userId])
  @@map("recurring_series")
}

// ----- CalendarEvent (cache from external provider) -----
model CalendarEvent {
  id         String   @id @default(uuid())
  calendarId String   @map("calendar_id")
  calendar   Calendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  externalId String   @map("external_id")
  title      String
  start      DateTime
  end        DateTime
  isBusy     Boolean  @default(true) @map("is_busy")
  isDeclined Boolean  @default(false) @map("is_declined")
  isAllDay   Boolean  @default(false) @map("is_all_day")
  colorId    String?  @map("color_id")
  syncedAt   DateTime @default(now()) @map("synced_at")

  @@unique([calendarId, externalId])
  @@index([calendarId, start])
  @@map("calendar_events")
}

// ----- Rituals -----
enum RitualKind {
  DAILY_PLAN
  DAILY_SHUTDOWN
  WEEKLY_PLAN
  WEEKLY_REVIEW
  QUARTERLY_REVIEW
  ANNUAL_REVIEW
  CUSTOM
}

enum RitualCadence {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  ANNUALLY
  ON_DEMAND
}

enum RitualStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

model Ritual {
  id            String        @id @default(uuid())
  userId        String?       @map("user_id") // null = system template
  user          User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind          RitualKind
  name          String
  cadence       RitualCadence
  scheduledTime String?       @map("scheduled_time") // "08:00" or cron-like
  steps         Json // [{type:"PROMPT", key, text}, ...]
  isEnabled     Boolean       @default(true) @map("is_enabled")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  instances RitualInstance[]

  @@index([userId, kind])
  @@map("rituals")
}

model RitualInstance {
  id           String       @id @default(uuid())
  ritualId     String       @map("ritual_id")
  ritual       Ritual       @relation(fields: [ritualId], references: [id], onDelete: Cascade)
  userId       String       @map("user_id")
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduledFor DateTime     @map("scheduled_for")
  startedAt    DateTime?    @map("started_at")
  completedAt  DateTime?    @map("completed_at")
  status       RitualStatus @default(PENDING)
  snapshot     Json? // captured state at completion
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  reflections ReflectionEntry[]

  @@index([userId, scheduledFor])
  @@index([ritualId])
  @@map("ritual_instances")
}

model ReflectionEntry {
  id               String         @id @default(uuid())
  ritualInstanceId String         @map("ritual_instance_id")
  ritualInstance   RitualInstance @relation(fields: [ritualInstanceId], references: [id], onDelete: Cascade)
  promptKey        String         @map("prompt_key")
  body             String
  attachedGoalId   String?        @map("attached_goal_id")
  attachedGoal     Goal?          @relation(fields: [attachedGoalId], references: [id], onDelete: SetNull)
  createdAt        DateTime       @default(now()) @map("created_at")

  @@index([ritualInstanceId])
  @@map("reflection_entries")
}

// ----- Command (granular undo) -----
enum CommandSource {
  USER_ACTION
  AUTO_RESCHEDULER
  ROLLOVER_JOB
  SYNC_JOB
}

model Command {
  id              String        @id @default(uuid())
  userId          String        @map("user_id")
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            String // "AUTO_RESCHEDULE" | "MOVE_SESSION" | ...
  payload         Json // { changes: [{entity, id, before, after}, ...], result?: any }
  isUndone        Boolean       @default(false) @map("is_undone")
  triggeredBy     CommandSource @map("triggered_by")
  parentCommandId String?       @map("parent_command_id")
  parent          Command?      @relation("CommandChildren", fields: [parentCommandId], references: [id], onDelete: SetNull)
  children        Command[]     @relation("CommandChildren")
  // Client-supplied UUID for idempotent retries. When the same key arrives
  // twice (network retry, mobile replay, double-click), the second request
  // returns the cached result from the first command instead of re-executing.
  idempotencyKey  String?       @unique @map("idempotency_key")
  createdAt       DateTime      @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@map("commands")
}

// ----- TimerEvent (for late-timer detector + audit) -----
enum TimerEventType {
  START
  PAUSE
  RESUME
  STOP
  COMPLETE
}

model TimerEvent {
  id        String         @id @default(uuid())
  taskId    String         @map("task_id")
  task      Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  type      TimerEventType
  timestamp DateTime       @default(now())
  metadata  Json? // { previousSessionStart, movedTo, ... }

  @@index([taskId, timestamp])
  @@map("timer_events")
}

// ----- Task additive enum -----
enum TaskKind {
  TASK
  HABIT
}

enum TaskBucket {
  TODAY
  TOMORROW
  NEXT_WEEK
  NEXT_MONTH
  NEXT_QUARTER
  NEXT_YEAR
  SOMEDAY
  NEVER
}

// ---------------------------------------------------------------------------
// Second Brain — Phase 1 MVP (text only; audio/graph come in Phase 2)
// ---------------------------------------------------------------------------

model BrainEntry {
  id     String @id @default(uuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Source (Phase 1 = text; audio fields pre-wired for Phase 2)
  sourceType    String  @default("text") @map("source_type") // text | audio | whatsapp | import
  sourceDevice  String? @map("source_device")
  audioUrl      String? @map("audio_url")
  audioDuration Int?    @map("audio_duration")
  audioSize     Int?    @map("audio_size")
  rawTranscript String? @map("raw_transcript") // the user's text (for text) or transcript (for audio)
  language      String? @default("en")

  // AI-produced output
  title             String?
  summary           String?
  structuredContent String? @map("structured_content")
  topics            Json    @default("[]")
  sentiment         String?
  actionItems       Json    @default("[]") @map("action_items")
  aiMetadata        Json?   @map("ai_metadata")

  // Pipeline state
  status       String    @default("pending") // pending | transcribing | analyzing | complete | failed
  errorMessage String?   @map("error_message")
  processedAt  DateTime? @map("processed_at")

  // User overrides
  userTitle  String? @map("user_title")
  isPinned   Boolean @default(false) @map("is_pinned")
  isArchived Boolean @default(false) @map("is_archived")

  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  crossLinks  BrainCrossLink[]
  occurrences BrainConceptOccurrence[]

  @@index([userId])
  @@index([userId, status])
  @@index([userId, deletedAt])
  @@index([userId, createdAt])
  @@map("brain_entries")
}

model BrainCrossLink {
  id      String     @id @default(uuid())
  userId  String     @map("user_id")
  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  entryId String     @map("entry_id")
  entry   BrainEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  targetType  String  @map("target_type") // task | goal | habit | note
  targetId    String  @map("target_id")
  linkType    String  @default("related") @map("link_type") // related | spawned_from | action_for | evidence_for
  aiGenerated Boolean @default(true) @map("ai_generated")

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([entryId, targetType, targetId])
  @@index([userId])
  @@index([entryId])
  @@index([targetType, targetId])
  @@map("brain_cross_links")
}

// ─── Second Brain — Concept Graph (Phase 5) ──────────────────────────────────
// Concepts are the atomic recurring units extracted from brain entries.
// Embeddings (pgvector) drive semantic dedupe; edges encode co-occurrence with
// Hebbian-weighted reinforcement; clusters group concepts into themes.

model BrainConcept {
  id     String @id @default(uuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name           String
  normalizedName String @map("normalized_name") // lowercase + NFKC + trim — used for unique constraint
  kind           String @default("idea") // person | place | project | idea | emotion | decision | tool

  embedding Unsupported("vector(1536)")?

  clusterId String?       @map("cluster_id")
  cluster   BrainCluster? @relation(fields: [clusterId], references: [id], onDelete: SetNull)

  centralityScore Float    @default(0) @map("centrality_score")
  mentionCount    Int      @default(0) @map("mention_count")
  lastMentionedAt DateTime @default(now()) @map("last_mentioned_at")

  // Soft-merge: when user merges duplicates we keep the row but redirect.
  mergedIntoId String? @map("merged_into_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  occurrences BrainConceptOccurrence[]
  edgesOut    BrainConceptEdge[]       @relation("EdgesOut")
  edgesIn     BrainConceptEdge[]       @relation("EdgesIn")

  @@unique([userId, normalizedName])
  @@index([userId, lastMentionedAt])
  @@index([userId, clusterId])
  @@map("brain_concepts")
}

model BrainConceptEdge {
  id              String @id @default(uuid())
  userId          String @map("user_id")
  user            User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceConceptId String @map("source_concept_id")
  targetConceptId String @map("target_concept_id")

  source BrainConcept @relation("EdgesOut", fields: [sourceConceptId], references: [id], onDelete: Cascade)
  target BrainConcept @relation("EdgesIn", fields: [targetConceptId], references: [id], onDelete: Cascade)

  // co_mentioned (default) | causes | caused_by | supports | contradicts | part_of | contains | precedes | related_to
  relationType     String   @default("co_mentioned") @map("relation_type")
  weight           Float    @default(1)
  mentionCount     Int      @default(1) @map("mention_count")
  lastReinforcedAt DateTime @default(now()) @map("last_reinforced_at")
  llmConfidence    Float?   @map("llm_confidence")

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([sourceConceptId, targetConceptId, relationType])
  @@index([userId, lastReinforcedAt])
  @@index([sourceConceptId])
  @@index([targetConceptId])
  @@map("brain_concept_edges")
}

model BrainConceptOccurrence {
  id        String       @id @default(uuid())
  conceptId String       @map("concept_id")
  concept   BrainConcept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  entryId   String       @map("entry_id")
  entry     BrainEntry   @relation(fields: [entryId], references: [id], onDelete: Cascade)

  salience Float   @default(0.5)
  quote    String? @db.Text // verbatim snippet for dual-coding hover

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([conceptId, entryId])
  @@index([entryId])
  @@map("brain_concept_occurrences")
}

model BrainCluster {
  id     String @id @default(uuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  label             String
  color             String                       @default("#6366f1")
  centroidEmbedding Unsupported("vector(1536)")? @map("centroid_embedding")
  conceptCount      Int                          @default(0) @map("concept_count")
  computedAt        DateTime                     @default(now()) @map("computed_at")

  concepts BrainConcept[]

  @@index([userId])
  @@map("brain_clusters")
}

// ─── Ambassador / Referral Program ───────────────────────────────────────────

model Ambassador {
  id     String @id @default(cuid())
  userId String @unique @map("user_id")
  user   User   @relation("AmbassadorUser", fields: [userId], references: [id], onDelete: Cascade)

  status          AmbassadorStatus @default(PENDING)
  rejectionReason String?          @map("rejection_reason")

  fullName        String              @map("full_name")
  contactPhone    String?             @map("contact_phone")
  country         String // ISO-2
  primaryPlatform AmbassadorPlatform  @map("primary_platform")
  primaryHandle   String              @map("primary_handle")
  audienceSize    Int?                @map("audience_size")
  niche           String?
  motivation      String              @db.Text
  promoChannels   String[]            @map("promo_channels")
  sampleUrls      String[]            @map("sample_urls")
  socialLinks     Json?               @map("social_links")
  payoutMethod    String?             @map("payout_method") // 'paypal' | 'wise' | 'bank'
  payoutDetails   Json?               @map("payout_details")
  agreedToTerms   Boolean             @default(false) @map("agreed_to_terms")

  referralCode        String?  @unique @map("referral_code")
  tierId              String?  @map("tier_id")
  tier                AmbassadorTier? @relation(fields: [tierId], references: [id])
  customCommissionPct Decimal? @map("custom_commission_pct") @db.Decimal(5, 2)

  appliedAt  DateTime  @default(now()) @map("applied_at")
  reviewedAt DateTime? @map("reviewed_at")
  reviewedBy String?   @map("reviewed_by")
  approvedAt DateTime? @map("approved_at")

  referrals      Referral[]
  payouts        AmbassadorPayout[]
  commissions    Commission[]
  referredUsers  User[]             @relation("AmbassadorReferrer")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([referralCode])
  @@map("ambassadors")
}

model AmbassadorTier {
  id                 String   @id @default(uuid())
  name               String   @unique
  order              Int      @unique
  minActiveReferrals Int      @map("min_active_referrals")
  commissionPct      Decimal  @map("commission_pct") @db.Decimal(5, 2)
  perks              String[]
  badgeColor         String?  @map("badge_color")
  ambassadors        Ambassador[]
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("ambassador_tiers")
}

model Referral {
  id             String     @id @default(cuid())
  ambassadorId   String     @map("ambassador_id")
  ambassador     Ambassador @relation(fields: [ambassadorId], references: [id], onDelete: Cascade)
  referredUserId String     @unique @map("referred_user_id")
  referredUser   User       @relation("ReferredUser", fields: [referredUserId], references: [id], onDelete: Cascade)

  source      ReferralSource @default(SIGNUP_CODE)
  status      ReferralStatus @default(SIGNED_UP)
  firstPaidAt DateTime?      @map("first_paid_at")
  churnedAt   DateTime?      @map("churned_at")

  commissions Commission[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([ambassadorId, status])
  @@map("referrals")
}

model Commission {
  id           String     @id @default(cuid())
  ambassadorId String     @map("ambassador_id")
  ambassador   Ambassador @relation(fields: [ambassadorId], references: [id], onDelete: Cascade)
  referralId   String     @map("referral_id")
  referral     Referral   @relation(fields: [referralId], references: [id], onDelete: Cascade)

  periodMonth      String  @map("period_month") // 'YYYY-MM'
  subscriptionId   String? @map("subscription_id")
  grossAmountCents Int     @map("gross_amount_cents")
  commissionPct    Decimal @map("commission_pct") @db.Decimal(5, 2)
  amountCents      Int     @map("amount_cents")

  status   CommissionStatus  @default(PENDING)
  payoutId String?           @map("payout_id")
  payout   AmbassadorPayout? @relation(fields: [payoutId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([referralId, periodMonth])
  @@index([ambassadorId, status])
  @@map("commissions")
}

model AmbassadorPayout {
  id           String     @id @default(cuid())
  ambassadorId String     @map("ambassador_id")
  ambassador   Ambassador @relation(fields: [ambassadorId], references: [id], onDelete: Cascade)
  amountCents  Int        @map("amount_cents")
  method       String // 'paypal' | 'wise' | 'manual' | 'bank'
  externalRef  String?    @map("external_ref")
  notes        String?
  paidAt       DateTime   @map("paid_at")
  paidBy       String     @map("paid_by")
  commissions  Commission[]
  createdAt    DateTime   @default(now()) @map("created_at")

  @@index([ambassadorId])
  @@map("ambassador_payouts")
}

enum AmbassadorStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum AmbassadorPlatform {
  YOUTUBE
  INSTAGRAM
  TIKTOK
  TWITTER
  NEWSLETTER
  BLOG
  PODCAST
  LINKEDIN
  OTHER
}

enum ReferralSource {
  SIGNUP_CODE
  LATE_ENTRY
  LINK
}

enum ReferralStatus {
  SIGNED_UP
  TRIAL
  ACTIVE
  CHURNED
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  CLAWED_BACK
}
