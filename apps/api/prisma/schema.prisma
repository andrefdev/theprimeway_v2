datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model SubscriptionPlan {
  id                       String    @id @default(uuid())
  name                     String
  displayName              String    @map("display_name")
  description              String?
  price                    Decimal
  currency                 String    @default("USD")
  billingInterval          String    @default("monthly") @map("billing_interval")
  lemonSqueezyProductId    String?   @map("lemon_squeezy_product_id")
  lemonSqueezyVariantId    String?   @unique @map("lemon_squeezy_variant_id")
  trialPeriodDays          Int?      @default(14) @map("trial_period_days")
  maxHabits                Int?      @default(5) @map("max_habits")
  maxGoals                 Int?      @default(3) @map("max_goals")
  maxTasks                 Int?      @default(20) @map("max_tasks")
  maxPomodoroSessionsDaily Int?      @default(10) @map("max_pomodoro_sessions_daily")
  maxBrainEntries          Int?      @default(20) @map("max_brain_entries")
  hasAiAssistant           Boolean?  @default(false) @map("has_ai_assistant")
  hasBrainModule           Boolean?  @default(false) @map("has_brain_module")
  hasBrainGraph            Boolean?  @default(false) @map("has_brain_graph")
  hasAdvancedAnalytics     Boolean?  @default(false) @map("has_advanced_analytics")
  hasCustomThemeCreation   Boolean?  @default(false) @map("has_custom_theme_creation")
  hasExportData            Boolean?  @default(false) @map("has_export_data")
  hasPrioritySupport       Boolean?  @default(false) @map("has_priority_support")
  isActive                 Boolean?  @default(true) @map("is_active")
  sortOrder                Int?      @default(0) @map("sort_order")
  createdAt                DateTime? @default(now()) @map("created_at")
  updatedAt                DateTime? @updatedAt @map("updated_at")

  subscriptions UserSubscription[]

  @@map("subscription_plans")
}

// HabitLog retains its role as a per-day completion marker.
// Habits themselves now live as Task{kind: HABIT}. taskId FK points to Task.
model HabitLog {
  id             String   @id @default(uuid())
  taskId         String   @map("task_id")
  task           Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId         String   @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date           DateTime
  completedCount Int      @default(0) @map("completed_count")
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([taskId, date])
  @@index([userId])
  @@map("habit_logs")
}

model LemonSqueezyWebhook {
  id             String    @id @default(uuid())
  eventName      String    @map("event_name")
  lemonSqueezyId String?   @map("lemon_squeezy_id")
  userId         String?   @map("user_id")
  user           User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionId String?   @map("subscription_id")
  webhookData    Json      @map("webhook_data")
  processed      Boolean?  @default(false)
  errorMessage   String?   @map("error_message")
  createdAt      DateTime? @default(now()) @map("created_at")

  subscription UserSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("lemon_squeezy_webhooks")
}

model Task {
  id                       String    @id @default(uuid())
  userId                   String?   @map("user_id")
  user                     User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title                    String
  description              String?
  status                   String    @default("open") // open | completed
  priority                 String    @default("medium")
  dueDate                  DateTime? @map("due_date")
  completedAt              DateTime? @map("completed_at")
  tags                     Json      @default("[]")
  estimatedDurationMinutes Int?      @map("estimated_duration_minutes")
  actualDurationMinutes    Int?      @default(0) @map("actual_duration_minutes")
  actualDurationSeconds    Int?      @default(0) @map("actual_duration_seconds")
  scheduledDate            DateTime? @map("scheduled_date") // YYYY-MM-DD intent (stored as datetime)
  scheduledStart           DateTime? @map("scheduled_start") // Full datetime for calendar
  scheduledEnd             DateTime? @map("scheduled_end") // Full datetime for calendar
  actualStart              DateTime? @map("actual_start") // When task actually started
  actualEnd                DateTime? @map("actual_end") // When task actually ended
  isAllDay                 Boolean?  @default(false) @map("is_all_day")
  source                   String?   @default("manual") // manual|autoschedule|dragged|recovered
  backlogState             String?   @default("none") @map("backlog_state")
  archivedAt               DateTime? @map("archived_at") // When task was archived
  orderInDay               Int?      @map("order_in_day") // Sort order within day
  lockedTime               Boolean?  @default(false) @map("locked_time") // User pinned time slot
  syncToCalendar           Boolean?  @default(false) @map("sync_to_calendar") // Sync task to Google Calendar
  lastReminderSentAt       DateTime? @map("last_reminder_sent_at") // Prevent duplicate reminders
  aiTimebox                Int?      @map("ai_timebox") // AI-suggested timebox in minutes
  aiInsightJson            Json?     @map("ai_insight_json") // AI-generated insights for task
  isRecurring              Boolean   @default(false) @map("is_recurring")
  recurrenceRule           String?   @map("recurrence_rule") // "daily", "weekly", "monthly", "weekdays", "custom:MO,WE,FR"
  recurringParentId        String?   @map("recurring_parent_id") // If this task is an instance generated from a recurring parent
  recurrenceEndDate        DateTime? @map("recurrence_end_date")

  // Vision-to-Execution OS additive fields (Phase 1)
  kind               TaskKind  @default(TASK)
  identityStatement  String?   @map("identity_statement") // for HABIT kind
  channelId          String?   @map("channel_id")
  day                DateTime? @db.Date // null = backlog
  positionInDay      Float?    @map("position_in_day") // fractional indexing
  plannedTimeMinutes Int?      @map("planned_time_minutes")
  actualTimeMinutes  Int       @default(0) @map("actual_time_minutes")
  rolloverCount      Int       @default(0) @map("rollover_count")
  originalDay        DateTime? @map("original_day") @db.Date
  recurringSeriesId  String?   @map("recurring_series_id")
  habitMeta          Json?     @map("habit_meta") // { category, color, targetFrequency, frequencyType, weekDays } when kind=HABIT
  scheduledBucket    TaskBucket? @map("scheduled_bucket")
  acceptanceCriteria String?   @map("acceptance_criteria") // "What does done look like?" — captured in focus pre-flight

  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  workingSessions    WorkingSession[]
  subtasks           Subtask[]
  timerEvents        TimerEvent[]
  goalLinks          TaskGoal[]
  habitLogs          HabitLog[]
  channel            Channel?              @relation(fields: [channelId], references: [id], onDelete: SetNull)
  recurringSeries    RecurringSeries?      @relation(fields: [recurringSeriesId], references: [id], onDelete: SetNull)
  recurringParent    Task?                 @relation("RecurringInstances", fields: [recurringParentId], references: [id], onDelete: SetNull)
  recurringInstances Task[]                @relation("RecurringInstances")

  @@index([userId])
  @@index([userId, status])
  @@index([userId, scheduledDate])
  @@index([userId, day])
  @@index([userId, kind])
  @@index([userId, scheduledBucket])
  @@index([channelId])
  @@index([recurringSeriesId])
  @@index([recurringParentId])
  @@map("tasks")
}

model UserProfile {
  id                String    @id @default(uuid())
  userId            String?   @map("user_id")
  user              User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName         String?   @map("first_name")
  lastName          String?   @map("last_name")
  displayName       String?   @map("display_name")
  profilePicture    String?   @map("profile_picture")
  bio               String?
  primaryGoal       String?   @map("primary_goal")
  lastProfileUpdate DateTime? @default(now()) @map("last_profile_update")
  createdAt         DateTime? @default(now()) @map("created_at")
  updatedAt         DateTime? @updatedAt @map("updated_at")

  @@unique([userId])
  @@map("user_profiles")
}

model UserSettings {
  id            String  @id @default(uuid())
  userId        String? @map("user_id")
  user          User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  locale        String  @default("en")
  theme         String  @default("dark")
  timezone      String  @default("UTC")
  aiDataSharing Boolean @default(true) @map("ai_data_sharing")

  // GENERAL
  startOfWeek          StartOfWeek      @default(MONDAY) @map("start_of_week")
  timeFormat           TimeFormat       @default(H24) @map("time_format")
  taskRolloverPosition RolloverPosition @default(TOP) @map("task_rollover_position")
  countPlannedAsActual Boolean          @default(false) @map("count_planned_as_actual")

  // WORKLOAD
  workloadThresholdMinutes Int   @default(420) @map("workload_threshold_minutes")
  customDayThresholds      Json? @map("custom_day_thresholds")

  // TIMEBOXING
  autoSchedulingGapMinutes        Int     @default(5) @map("auto_scheduling_gap_minutes")
  defaultTaskDurationMinutes      Int     @default(30) @map("default_task_duration_minutes")
  autoRescheduleOnConflict        Boolean @default(true) @map("auto_reschedule_on_conflict")
  autoRescheduleOnEarlyCompletion Boolean @default(true) @map("auto_reschedule_on_early_completion")
  contiguityThresholdMinutes      Int     @default(10) @map("contiguity_threshold_minutes")

  // EXTENSION: late-timer detector
  detectLateTimerStart      Boolean       @default(true) @map("detect_late_timer_start")
  lateTimerThresholdMinutes Int           @default(15) @map("late_timer_threshold_minutes")
  lateTimerMode             LateTimerMode @default(PROMPT) @map("late_timer_mode")

  // RITUALS
  // planDayAtTime / endDayAtTime are local-clock "HH:mm" strings interpreted in `timezone`.
  // Materialized RitualInstance.scheduledFor is always UTC.
  planDayAtTime       String? @default("08:00") @map("plan_day_at_time")
  endDayAtTime        String? @default("18:00") @map("end_day_at_time")
  autoRolloverEnabled Boolean @default(true) @map("auto_rollover_enabled")

  // AI
  channelRecommendationsEnabled     Boolean @default(true) @map("channel_recommendations_enabled")
  plannedTimeRecommendationsEnabled Boolean @default(true) @map("planned_time_recommendations_enabled")

  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@unique([userId])
  @@map("user_settings")
}

enum StartOfWeek {
  SUNDAY
  MONDAY
}

enum TimeFormat {
  H12
  H24
}

enum RolloverPosition {
  TOP
  BOTTOM
}

enum LateTimerMode {
  OFF
  PROMPT
  AUTO
}

model UserSubscription {
  id                         String    @id @default(uuid())
  userId                     String?   @map("user_id")
  user                       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId                     String?   @map("plan_id")
  lemonSqueezySubscriptionId String?   @map("lemon_squeezy_subscription_id")
  lemonSqueezyOrderId        String?   @map("lemon_squeezy_order_id")
  lemonSqueezyCustomerId     String?   @map("lemon_squeezy_customer_id")
  updatePaymentMethodUrl     String?   @map("update_payment_method_url")
  status                     String?   @default("pending")
  currency                   String?   @default("USD")
  amount                     Decimal
  billingInterval            String    @map("billing_interval")
  trialStartsAt              DateTime? @map("trial_starts_at")
  trialEndsAt                DateTime? @map("trial_ends_at")
  startsAt                   DateTime  @map("starts_at")
  endsAt                     DateTime? @map("ends_at")
  cancelledAt                DateTime? @map("cancelled_at")
  nextBillingDate            DateTime? @map("next_billing_date")
  metadata                   Json?     @map("metadata")
  createdAt                  DateTime? @default(now()) @map("created_at")
  updatedAt                  DateTime? @updatedAt @map("updated_at")

  plan     SubscriptionPlan?     @relation(fields: [planId], references: [id], onDelete: SetNull)
  webhooks LemonSqueezyWebhook[]

  @@unique([lemonSqueezySubscriptionId])
  @@index([userId])
  @@index([planId])
  @@map("user_subscriptions")
}

model UserUsageStat {
  id                    String    @id @default(uuid())
  userId                String?   @map("user_id")
  user                  User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentHabits         Int?      @default(0) @map("current_habits")
  currentGoals          Int?      @default(0) @map("current_goals")
  currentNotes          Int?      @default(0) @map("current_notes")
  currentTasks          Int?      @default(0) @map("current_tasks")
  dailyPomodoroSessions Int?      @default(0) @map("daily_pomodoro_sessions")
  dailyAiRequests       Int?      @default(0) @map("daily_ai_requests")
  monthlyExports        Int?      @default(0) @map("monthly_exports")
  dailyResetDate        DateTime? @map("daily_reset_date")
  monthlyResetDate      DateTime? @map("monthly_reset_date")
  createdAt             DateTime? @default(now()) @map("created_at")
  updatedAt             DateTime? @updatedAt @map("updated_at")

  @@unique([userId])
  @@index([userId])
  @@map("user_usage_stats")
}

model UserFeatureOverride {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  featureKey String   @map("feature_key")
  enabled    Boolean
  reason     String?
  createdBy  String?  @map("created_by")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([userId, featureKey])
  @@index([userId])
  @@map("user_feature_overrides")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?

  accounts Account[]
  sessions Session[]

  // Habits (habits are Task{kind:HABIT}; HabitLog retains per-day completion)
  habitLogs HabitLog[]

  // Tasks
  tasks            Task[]
  calendarAccounts CalendarAccount[]

  // Profile & Settings
  profile              UserProfile?
  settings             UserSettings?
  subscriptions        UserSubscription[]
  lemonSqueezyWebhooks LemonSqueezyWebhook[]

  // Chat
  chatThreads ChatThread[]

  // System
  pushSubscriptions       PushSubscription[]
  usageStats              UserUsageStat?
  devices                 UserDevice[]
  notificationPreferences NotificationPreferences?
  notifications           Notification[]
  onboarding              UserOnboarding?

  // Personalization
  sectionCustomizations SectionCustomization[]

  // Gamification
  gamificationProfile GamificationProfile?
  xpEvents            XpEvent[]
  dailyXpSnapshots    DailyXpSnapshot[]
  userAchievements    UserAchievement[]
  achievementProgress UserAchievementProgress[]
  dailyChallenges     DailyChallenge[]

  // Feature flags
  role             UserRole              @default(USER)
  featureOverrides UserFeatureOverride[]

  // Vision-to-Execution OS (Phase 1)
  vision              Vision?
  goals               Goal[]
  contexts            Context[]
  channels            Channel[]
  workingSessions      WorkingSession[]
  workingHoursEntries  WorkingHours[]
  workingHoursOverrides WorkingHoursOverride[]
  recurringSeries     RecurringSeries[]
  rituals             Ritual[]
  ritualInstances     RitualInstance[]
  commands            Command[]

  // Public API + webhooks (Phase 4)
  apiKeys  ApiKey[]
  webhooks Webhook[]

  // Second Brain (Phase 4 MVP — text only)
  brainEntries    BrainEntry[]
  brainCrossLinks BrainCrossLink[]
  brainConcepts   BrainConcept[]
  brainConceptEdges BrainConceptEdge[]
  brainClusters   BrainCluster[]

  // Ambassador / Referral program
  referredByAmbassadorId String?   @map("referred_by_ambassador_id")
  referredByAmbassador   Ambassador? @relation("AmbassadorReferrer", fields: [referredByAmbassadorId], references: [id], onDelete: SetNull)
  referralEnteredAt      DateTime? @map("referral_entered_at")
  ambassador             Ambassador? @relation("AmbassadorUser")
  referralRecord         Referral?   @relation("ReferredUser")
}

enum UserRole {
  USER
  ADMIN
}

// ---------------------------------------------------------------------------
// Public API keys + Webhooks
// ---------------------------------------------------------------------------
model ApiKey {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  prefix     String    @unique
  hashedKey  String    @map("hashed_key")
  lastUsedAt DateTime? @map("last_used_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("api_keys")
}

model Webhook {
  id               String    @id @default(uuid())
  userId           String    @map("user_id")
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  url              String
  events           String[]
  secret           String
  isActive         Boolean   @default(true) @map("is_active")
  lastDeliveryAt   DateTime? @map("last_delivery_at")
  lastDeliveryCode Int?      @map("last_delivery_code")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@map("webhooks")
}

model NotificationPreferences {
  id     String @id @default(uuid())
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Notification types - ALL enabled by default
  habitReminders    Boolean @default(true) @map("habit_reminders")
  pomodoroAlerts    Boolean @default(true) @map("pomodoro_alerts")
  taskReminders     Boolean @default(true) @map("task_reminders")
  dailyMotivation   Boolean @default(true) @map("daily_motivation")
  marketingMessages Boolean @default(true) @map("marketing_messages")

  // Reminder configuration
  taskReminderOffset Int    @default(30) @map("task_reminder_offset") // minutes before due
  habitReminderTime  String @default("20:00") @map("habit_reminder_time") // HH:mm user local time

  // Cron de-dup: set after a habit reminder push fires so the 10-min cron tick
  // does not re-send on the same local day.
  lastHabitReminderAt DateTime? @map("last_habit_reminder_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("notification_preferences")
}

model Notification {
  id     String @id @default(uuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type     String // overdue_task | habit_missed | pending_transaction | smart_reminder | system
  entityId String? @map("entity_id") // task/habit/tx id for dedup + linking
  title    String
  message  String
  href     String?
  urgency  String? // high | medium | low
  data     Json? // arbitrary extra payload

  readAt      DateTime? @map("read_at")
  dismissedAt DateTime? @map("dismissed_at")

  // Push throttle: set when a push for this notification was sent. The inbox
  // sync uses it to throttle to one push per entityId per local day, so a
  // user that polls the inbox every minute does not get spammed.
  lastPushSentAt DateTime? @map("last_push_sent_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, type, entityId], name: "user_type_entity")
  @@index([userId, dismissedAt, readAt, createdAt])
  @@map("notifications")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId], name: "provider_providerAccountId")
  @@index([userId])
  @@map("auth_accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("auth_sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("auth_verification_tokens")
}

model PushSubscription {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String
  keys      Json      @default("{}")
  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@unique([endpoint])
  @@index([userId])
  @@map("push_subscriptions")
}

// One-time password for email verification + password reset
model EmailOtp {
  id        String   @id @default(uuid())
  email     String
  codeHash  String   @map("code_hash")
  purpose   String // "register" | "reset"
  expiresAt DateTime @map("expires_at")
  attempts  Int      @default(0) @map("attempts")
  consumed  Boolean  @default(false) @map("consumed")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email, purpose])
  @@map("email_otp")
}

model ChatThread {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String?
  lastMessageAt DateTime? @map("last_message_at")
  createdAt     DateTime? @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt @map("updated_at")

  messages ChatMessage[]

  @@index([userId])
  @@map("chat_threads")
}

model ChatMessage {
  id        String    @id @default(uuid())
  threadId  String    @map("thread_id")
  role      String
  content   String
  model     String?
  toolName  String?   @map("tool_name")
  toolCalls Json?     @map("tool_calls")
  createdAt DateTime? @default(now()) @map("created_at")

  thread ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@map("chat_messages")
}

model CalendarAccount {
  id                      String    @id @default(uuid())
  userId                  String?   @map("user_id")
  user                    User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider                String
  email                   String?
  accessToken             String?
  refreshToken            String?
  expiresAt               DateTime?
  scopes                  Json?
  isPrimary               Boolean?  @default(false)
  defaultTargetCalendarId String?   @map("default_target_calendar_id")
  createdAt               DateTime? @default(now()) @map("created_at")
  updatedAt               DateTime? @updatedAt @map("updated_at")

  calendars Calendar[]

  @@index([userId])
  @@map("calendar_accounts")
}

model Calendar {
  id                 String    @id @default(uuid())
  calendarAccountId  String    @map("calendar_account_id")
  providerCalendarId String
  name               String
  color              String?
  isPrimary          Boolean?  @default(false)
  isSelectedForSync  Boolean?  @default(false)
  accessRole         String?   @map("access_role")
  createdAt          DateTime? @default(now()) @map("created_at")
  updatedAt          DateTime? @updatedAt @map("updated_at")

  account       CalendarAccount        @relation(fields: [calendarAccountId], references: [id], onDelete: Cascade)
  watchChannels CalendarWatchChannel[]
  events        CalendarEvent[]

  @@index([calendarAccountId])
  @@map("calendars")
}

model CalendarWatchChannel {
  id         String   @id @default(uuid())
  calendarId String   @map("calendar_id")
  channelId  String   @unique @map("channel_id")
  resourceId String   @map("resource_id")
  token      String?
  syncToken  String?  @map("sync_token")
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  calendar Calendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)

  @@index([calendarId])
  @@index([expiresAt])
  @@map("calendar_watch_channels")
}

model UserDevice {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fcmToken   String   @unique @map("fcm_token")
  deviceType String   @map("device_type") // "web" | "android" | "ios"
  deviceName String?  @map("device_name")
  isActive   Boolean  @default(true) @map("is_active")
  lastUsedAt DateTime @default(now()) @map("last_used_at")
  createdAt  DateTime @default(now()) @map("created_at")
