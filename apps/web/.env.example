# OAuth - Google (https://console.cloud.google.com/apis/credentials)
VITE_GOOGLE_CLIENT_ID=

# OAuth - Apple (https://developer.apple.com/account/resources/serviceIds)
VITE_APPLE_CLIENT_ID=
VITE_APPLE_REDIRECT_URI=http://localhost:5173

# Sentry (https://sentry.io)
VITE_SENTRY_DSN=

# Firebase Web (Cloud Messaging) — all are PUBLIC client-side config
# Mirror values into apps/web/public/firebase-messaging-sw.js (can't read import.meta.env from SW)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=
